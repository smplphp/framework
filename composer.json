{
  "name"        : "smplphp/framework",
  "type"        : "library",
  "require"     : {
    "php"              : "^8.5",
    "ext-pdo"          : "*",
    "nesbot/carbon"    : "^3.1",
    "vlucas/phpdotenv" : "^5.6",
    "filp/whoops"      : "^2.18",
    "nikic/fast-route" : "^1.3",
    "monolog/monolog"  : "^3.10",
    "symfony/uid"      : "^8.0",
    "composer/composer": "^2.0",
    "webmozart/assert" : "^2.3"
  },
  "require-dev" : {
    "phpunit/phpunit"              : "^13.0",
    "phpstan/phpstan"              : "^2.1",
    "readalizer/readalizer"        : "^1.0",
    "jetbrains/phpstorm-attributes": "^1.2",
    "infection/infection"          : "^0.32.6",
    "friendsofphp/php-cs-fixer"    : "^3.94",
    "brianium/paratest"            : "^7.22"
  },
  "autoload"    : {
    "psr-4": {
      "Smpl\\Framework\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Smpl\\Framework\\Tests\\": "tests/"
    }
  },
  "config"      : {
    "allow-plugins": {
      "phpstan/extension-installer"  : true,
      "infection/extension-installer": true
    }
  },
  "scripts"     : {
    "test"         : "@php vendor/bin/paratest",
    "test:coverage": "@php vendor/bin/paratest --coverage-clover=build/logs/clover.xml --log-junit=build/report.junit.xml",
    "mutation"     : "@php vendor/bin/infection --threads=max --no-progress",
    "analyse"      : "@php vendor/bin/phpstan analyse src --memory-limit=2G",
    "tidy"         : "@php vendor/bin/php-cs-fixer fix",
    "suite"        : [
      "@tidy",
      "@analyse",
      "@test",
      "@mutation"
    ]
  }
}
